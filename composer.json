{
    "name": "particle-academy/fancy-seo",
    "description": "Server-rendered SEO + crawlability for Laravel + Inertia apps — per-route meta/Open Graph/Twitter/JSON-LD on the first byte, dynamic sitemap.xml / robots.txt / llms.txt, and per-page Markdown. The PHP baseline that pairs with @particle-academy/fancy-inertia's <Seo>.",
    "type": "library",
    "keywords": [
        "laravel",
        "inertia",
        "seo",
        "ssr",
        "sitemap",
        "robots",
        "json-ld",
        "open-graph",
        "llms-txt",
        "particle-academy"
    ],
    "license": "MIT",
    "homepage": "https://github.com/Particle-Academy/fancy-seo",
    "support": {
        "issues": "https://github.com/Particle-Academy/fancy-seo/issues",
        "source": "https://github.com/Particle-Academy/fancy-seo"
    },
    "authors": [
        {
            "name": "Particle Academy",
            "homepage": "https://github.com/Particle-Academy"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.26",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "FancySeo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FancySeo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "FancySeo\\FancySeoServiceProvider"
            ],
            "aliases": {
                "FancySeo": "FancySeo\\Facades\\FancySeo"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
